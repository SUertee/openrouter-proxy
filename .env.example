# Tokyo proxy auth
PROXY_TOKEN=replace-with-strong-token

# Upstream provider
UPSTREAM_BASE_URL=https://openrouter.ai
UPSTREAM_API_KEY=sk-or-v1-xxxx
UPSTREAM_TIMEOUT_SEC=120

# Optional OpenRouter attribution headers
UPSTREAM_HTTP_REFERER=https://your-app.example.com
UPSTREAM_X_TITLE=Yili Tokyo Proxy

# For usage check / direct benchmark
OPENROUTER_API_KEY=sk-or-v1-xxxx

# Runtime log level: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# Model list optimization for OpenWebUI
# Only keep latest N models per family from OpenRouter /models.
MODEL_FAMILIES=gemini,claude,openai,llama
MODEL_LIMIT_PER_FAMILY=2
MODELS_CACHE_TTL_SEC=600
